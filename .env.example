# PromptHash Stellar environment

# Shared runtime
STELLAR_SCAFFOLD_ENV=development
XDG_CONFIG_HOME=.config

# Frontend runtime
PUBLIC_STELLAR_NETWORK=TESTNET
PUBLIC_STELLAR_NETWORK_PASSPHRASE="Test SDF Network ; September 2015"
PUBLIC_STELLAR_RPC_URL=https://soroban-testnet.stellar.org
PUBLIC_STELLAR_HORIZON_URL=https://horizon-testnet.stellar.org
PUBLIC_PROMPT_HASH_CONTRACT_ID=CAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAA
PUBLIC_STELLAR_NATIVE_ASSET_CONTRACT_ID=CDLZFC3SYJYDZT7K67VZ75HPJVIEUVNIXF47ZG2FB2RMQQVU2HHGCYSC
PUBLIC_STELLAR_SIMULATION_ACCOUNT=GAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAA
PUBLIC_UNLOCK_PUBLIC_KEY=ZHVtbXktcHVibGljLWtleS12YWx1ZS1oZXJl

# Optional external chat gateway used by the current UI
PUBLIC_CHAT_API_BASE=https://secret-ai-gateway.onrender.com

# Serverless unlock runtime
CHALLENGE_TOKEN_SECRET=super-secret-challenge-token-string
UNLOCK_PUBLIC_KEY=ZHVtbXktcHVibGljLWtleS12YWx1ZS1oZXJl
UNLOCK_PRIVATE_KEY=ZHVtbXktcHJpdmF0ZS1rZXktdmFsdWUtaGVyZQ==

# Optional — unlock service rotation (see docs/secret-rotation.md)
# ADMIN_ROTATION_TOKEN=
# CHALLENGE_TOKEN_SECRET_PREVIOUS=
# CHALLENGE_TOKEN_ROTATION_TIMESTAMP=
# CHALLENGE_TOKEN_GRACE_PERIOD_MS=300000

# Optional — rate limiting (falls back to in-memory when unset)
# REDIS_URL=

# Comma-separated wallet allowlist for off-chain review moderation. Leave unset to disable moderation.
# MODERATOR_ADDRESSES=GMODERATORADDRESS...
